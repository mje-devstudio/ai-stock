{
    "tr_id": "au10001",
    "tr_name": "접근토큰 발급",
    "category": {
        "main": "OAuth 인증",
        "sub": "접근토큰발급"
    },
    "usage": {
        "description": "키움증권 REST API 서비스를 이용하기 위해 서버로부터 Bearer 형태의 접근 토큰(Access Token)을 발급받는 인증 TR입니다. 발급받은 토큰은 이후 모든 API 요청의 Authorization 헤더에 Bearer 토큰으로 포함하여 인증용으로 사용합니다.",
        "method": "POST",
        "environment_domains": {
            "production": "https://api.kiwoom.com",
            "mock_investment": "https://mockapi.kiwoom.com (KRX만 지원가능)"
        },
        "url_path": "/oauth2/token",
        "format": "JSON",
        "content_type": "application/json;charset=UTF-8"
    },
    "request": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
                "description": "7자리 TR코드를 세팅합니다. 이 TR의 경우 'au10001'을 입력합니다."
            },
            {
                "element": "authorization",
                "name_ko": "접근토큰",
                "type": "String",
                "required": true,
                "length": "1000",
                "description": "토큰 발급을 요청하는 시점이므로, 기본 토큰 타입 구조 명세에 맞춰 호출 예시처럼 빈 형태 또는 사전에 규정된 기초 인증 형태로 전달합니다."
            },
            {
                "element": "cont-yn",
                "name_ko": "연속조회여부",
                "type": "String",
                "required": false,
                "length": "1",
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음데이터 요청시 응답 Header의 cont-yn값 세팅 (토큰 발급 TR에서는 일반적으로 생략 가능)"
            },
            {
                "element": "next-key",
                "name_ko": "연속조회키",
                "type": "String",
                "required": false,
                "length": "50",
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음데이터 요청시 응답 Header의 next-key값 세팅 (토큰 발급 TR에서는 일반적으로 생략 가능)"
            }
        ],
        "body": [
            {
                "element": "grant_type",
                "name_ko": "인증 방식",
                "type": "String",
                "required": true,
                "length": null,
                "description": "반드시 'client_credentials' 값을 입력해야 합니다."
            },
            {
                "element": "appkey",
                "name_ko": "앱키",
                "type": "String",
                "required": true,
                "length": null,
                "description": "키움증권에서 발급받은 고유 App Key를 입력합니다."
            },
            {
                "element": "secretkey",
                "name_ko": "시크릿키",
                "type": "String",
                "required": true,
                "length": null,
                "description": "키움증권에서 발급받은 고유 Secret Key를 입력합니다."
            }
        ]
    },
    "response": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
                "description": "요청에 대응하여 처리된 7자리 TR코드가 반환됩니다. (예: au10001)"
            },
            {
                "element": "cont-yn",
                "name_ko": "연속조회여부",
                "type": "String",
                "required": false,
                "length": "1",
                "description": "다음 데이터가 있을 시 Y 값이 전달됩니다."
            },
            {
                "element": "next-key",
                "name_ko": "연속조회키",
                "type": "String",
                "required": false,
                "length": "50",
                "description": "다음 데이터가 있을 시 다음 키 값이 전달됩니다."
            }
        ],
        "body": [
            {
                "element": "expires_dt",
                "name_ko": "만료일시",
                "type": "String",
                "required": true,
                "length": null,
                "description": "발급된 접근 토큰의 만료 시간을 나타냅니다. 형식은 포맷에 따라 문자열(예: YYYYMMDDHHmmss)로 제공됩니다."
            },
            {
                "element": "token_type",
                "name_ko": "토큰타입",
                "type": "String",
                "required": true,
                "length": null,
                "description": "반환되는 토큰의 타입입니다. 주로 소문자 'bearer' 또는 대문자 'Bearer' 값으로 제공됩니다."
            },
            {
                "element": "token",
                "name_ko": "접근토큰",
                "type": "String",
                "required": true,
                "length": null,
                "description": "발급된 Access Token 본문 데이터 문자열입니다."
            },
            {
                "element": "return_code",
                "name_ko": "결과코드",
                "type": "Number",
                "required": true,
                "length": null,
                "description": "처리 결과를 뜻하며, 성공 시 0을 반환하고 오류가 발생할 경우 공통 오류 코드 세트를 반환합니다."
            },
            {
                "element": "return_msg",
                "name_ko": "결과메시지",
                "type": "String",
                "required": true,
                "length": null,
                "description": "처리 결과에 대한 상세 안내 메시지입니다. (예: 정상적으로 처리되었습니다)"
            }
        ]
    },
    "examples": {
        "request_example": {
            "headers": {
                "api-id": "au10001",
                "authorization": "Bearer ",
                "Content-Type": "application/json;charset=UTF-8"
            },
            "body": {
                "grant_type": "client_credentials",
                "appkey": "AxserEsdcredca.....",
                "secretkey": "SEefdcwcforehDre2fdvc...."
            }
        },
        "response_example": {
            "headers": {
                "api-id": "au10001",
                "cont-yn": "N",
                "next-key": ""
            },
            "body": {
                "expires_dt": "20241107083713",
                "token_type": "bearer",
                "return_code": 0,
                "token": "WQJCwyqInphKnR3bSRtB9NE1lv...",
                "return_msg": "정상적으로 처리되었습니다"
            }
        }
    },
    "precautions": [
        "토큰 발급을 위한 body 데이터 중 'grant_type' 필드에는 반드시 리터럴 문자열인 'client_credentials'를 오타 없이 입력하셔야 합니다.",
        "모의투자 도메인(mockapi.kiwoom.com)은 실거래 도메인과 구분되어야 하며, 모의투자 환경에서는 KRX(한국거래소) 시장 데이터 조회 관련 기능만 제한적으로 지원 가능합니다.",
        "발급 완료된 접근토큰(token)을 타 API TR 호출 시 Header 영역의 'authorization'에 삽입할 때에는 반드시 앞단에 토큰 타입인 \"Bearer \" (공백 한 칸 포함)를 결합하여 호출해야 합니다. (예시: 'Bearer WQJCwyqInphKn...')",
        "만약 잘못된 App Key 또는 Secret Key를 입력하거나 해당 키의 검증에 실패하는 경우, 공통 에러 응답 규격에 의거하여 오류코드 8001 또는 8002(App Key와 Secret Key 검증에 실패했습니다) 에러가 발생하므로 입력 값을 철저히 검증해야 합니다."
    ]
}