{
    "api_info": {
        "menu_location": "국내주식 > 주문 > 주식 매도주문(kt10001)",
        "api_name": "주식 매도주문",
        "api_id": "kt10001"
    },
    "basic_info": {
        "method": "POST",
        "prod_domain": "https://api.kiwoom.com",
        "mock_domain": "https://mockapi.kiwoom.com(KRX만 지원가능)",
        "url": "/api/dostk/ordr",
        "format": "JSON",
        "content_type": "application/json;charset=UTF-8"
    },
    "overview": "주식 매도 주문을 요청합니다.",
    "request": {
        "header": [
            {
                "element": "api-id",
                "name": "TR명",
                "type": "String",
                "required": true,
                "length": 10,
                "description": "7자리 TR코드, ex) ka00001"
            },
            {
                "element": "authorization",
                "name": "접근토큰",
                "type": "String",
                "required": true,
                "length": 1000,
                "description": "토큰 지정시 토큰타입(\"Bearer\") 붙혀서 호출 예) Bearer Egicyx..."
            },
            {
                "element": "cont-yn",
                "name": "연속조회여부",
                "type": "String",
                "required": false,
                "length": 1,
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음데이터 요청시 응답 Header의 cont-yn값 세팅"
            },
            {
                "element": "next-key",
                "name": "연속조회키",
                "type": "String",
                "required": false,
                "length": 50,
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음데이터 요청시 응답 Header의 next-key값 세팅"
            }
        ],
        "body": [
            {
                "element": "dmst_stex_tp",
                "name": "국내거래소구분",
                "type": "String",
                "required": true,
                "length": 3,
                "description": "KRX, NXT, SOR"
            },
            {
                "element": "stk_cd",
                "name": "종목코드",
                "type": "String",
                "required": true,
                "length": 12,
                "description": "주문할 주식의 종목코드"
            },
            {
                "element": "ord_qty",
                "name": "주문수량",
                "type": "String",
                "required": true,
                "length": 12,
                "description": "단위: 1주"
            },
            {
                "element": "ord_uv",
                "name": "주문단가",
                "type": "String",
                "required": false,
                "length": 12,
                "description": "단위: 원"
            },
            {
                "element": "trde_tp",
                "name": "매매구분",
                "type": "String",
                "required": true,
                "length": 2,
                "description": "0:보통, 3:시장가, 5:조건부지정가, 81:장마감후시간외, 61:장시작전시간외, 62:시간외단일가, 6:최유리지정가, 7:최우선지정가, 10:보통(IOC), 13:시장가(IOC), 16:최유리(IOC), 20:보통(FOK), 23:시장가(FOK), 26:최유리(FOK), 28:스톱지정가, 29:중간가, 30:중간가(IOC), 31:중간가(FOK)"
            },
            {
                "element": "cond_uv",
                "name": "조건단가",
                "type": "String",
                "required": false,
                "length": 12,
                "description": "단위: 원"
            }
        ]
    },
    "response": {
        "header": [
            {
                "element": "api-id",
                "name": "TR명",
                "type": "String",
                "required": true,
                "length": 10,
                "description": "7자리 TR코드, ex) ka00001"
            },
            {
                "element": "cont-yn",
                "name": "연속조회여부",
                "type": "String",
                "required": false,
                "length": 1,
                "description": "다음 데이터가 있을시 Y값 전달"
            },
            {
                "element": "next-key",
                "name": "연속조회키",
                "type": "String",
                "required": false,
                "length": 50,
                "description": "다음 데이터가 있을시 다음 키값 전달"
            }
        ],
        "body": [
            {
                "element": "ord_no",
                "name": "주문번호",
                "type": "String",
                "required": false,
                "length": 7,
                "description": "7자리 고유 주문번호"
            },
            {
                "element": "dmst_stex_tp",
                "name": "국내거래소구분",
                "type": "String",
                "required": false,
                "length": 6,
                "description": "KRX, NXT, SOR"
            },
            {
                "element": "return_code",
                "name": "결과코드",
                "type": "Number",
                "required": true,
                "description": "0: 정상 처리, 그 외: 에러"
            },
            {
                "element": "return_msg",
                "name": "결과메시지",
                "type": "String",
                "required": true,
                "description": "처리 결과에 대한 메시지"
            }
        ]
    },
    "examples": {
        "request": {
            "header": {
                "api-id": "kt10001",
                "authorization": "Bearer eyJhbGciOiJIUzI1NiIsIn..."
            },
            "body": {
                "dmst_stex_tp": "KRX",
                "stk_cd": "005930",
                "ord_qty": "10",
                "ord_uv": "75000",
                "trde_tp": "0",
                "cond_uv": ""
            }
        },
        "response": {
            "header": {
                "api-id": "kt10001",
                "cont-yn": "N",
                "next-key": ""
            },
            "body": {
                "ord_no": "00045",
                "dmst_stex_tp": "KRX",
                "return_code": 0,
                "return_msg": "정상적으로 처리되었습니다"
            }
        }
    },
    "precautions": [
        "모의투자 도메인(mockapi.kiwoom.com)을 이용할 경우 한국거래소(KRX) 상품만 매매가 가능합니다.",
        "매매구분(trde_tp)에 따라 '주문단가(ord_uv)' 및 '조건단가(cond_uv)'의 필수 입력 여부가 달라지므로 유의해야 합니다. 예를 들어, 시장가(3) 주문 시 주문단가는 공백으로 전송할 수 있습니다.",
        "Header의 authorization 필드 세팅 시 토큰 문자열 앞에 토큰 타입인 'Bearer '를 반드시 공백과 함께 붙여서 호출해야 합니다."
    ]
}