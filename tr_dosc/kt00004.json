{
    "tr_id": "kt00004",
    "tr_name": "계좌평가현황요청",
    "category": {
        "main": "국내주식",
        "sub": "계좌"
    },
    "usage": {
        "description": "사용자 계좌의 예수금, 유가잔고평가액, 총매입금액, 누적투자손익, 수익률 등의 전체 자금 현황(싱글 데이터)을 조회함과 동시에, 현재 계좌에 보유 중인 주식, ELW, ETN 등 개별 종목들의 보유 수량, 평균단가, 평가손익 및 손익률 목록(멀티 데이터 LIST)을 한 번에 일괄 반환합니다.",
        "method": "POST",
        "environment_domains": {
            "production": "https://api.kiwoom.com",
            "mock_investment": "https://mockapi.kiwoom.com (KRX만 지원가능)"
        },
        "url_path": "/api/dostk/acnt",
        "format": "JSON",
        "content_type": "application/json;charset=UTF-8"
    },
    "request": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
                "description": "7자리 TR코드를 세팅합니다. 이 TR의 경우 'kt00004'를 입력합니다."
            },
            {
                "element": "authorization",
                "name_ko": "접근토큰",
                "type": "String",
                "required": true,
                "length": "1000",
                "description": "발급받은 Access Token 앞에 'Bearer ' 접두사를 결합하여 헤더에 포함합니다."
            },
            {
                "element": "cont-yn",
                "name_ko": "연속조회여부",
                "type": "String",
                "required": false,
                "length": "1",
                "description": "보유 종목이 많아 다음 페이지가 존재할 경우 응답 Header의 cont-yn값이 Y로 전달됩니다. 다음 데이터 요청 시 이 값을 그대로 세팅합니다. (최초 조회 시 'N' 또는 생략)"
            },
            {
                "element": "next-key",
                "name_ko": "연속조회키",
                "type": "String",
                "required": false,
                "length": "50",
                "description": "응답 Header의 cont-yn값이 Y일 경우 다음 페이지 데이터를 호출하기 위해 응답받은 next-key값을 그대로 세팅합니다."
            }
        ],
        "body": [
            {
                "element": "qry_tp",
                "name_ko": "상장폐지조회구분",
                "type": "String",
                "required": true,
                "length": "1",
                "description": "0: 전체 조회, 1: 상장폐지종목 제외"
            },
            {
                "element": "dmst_stex_tp",
                "name_ko": "국내거래소구분",
                "type": "String",
                "required": true,
                "length": "6",
                "description": "KRX: 한국거래소, NXT: 넥스트트레이드(대체거래소)"
            }
        ]
    },
    "response": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
