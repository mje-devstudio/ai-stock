{
    "tr_id": "ka10001",
    "tr_name": "주식기본정보요청",
    "category": {
        "main": "국내주식",
        "sub": "종목정보"
    },
    "usage": {
        "description": "지정한 주식 종목의 자본금, 상장주식수, 시가총액, 외인소진률, PER, PBR, 매출액, 영업이익, 250일 최고/최저, 현재가, 대비, 등락률 등 주식의 가장 기본적인 재무 및 시세 요약 정보를 단건으로 조회합니다.",
        "method": "POST",
        "environment_domains": {
            "production": "https://api.kiwoom.com",
            "mock_investment": "https://mockapi.kiwoom.com(KRX만 지원가능)"
        },
        "url_path": "/api/dostk/stkinfo",
        "format": "JSON",
        "content_type": "application/json;charset=UTF-8"
    },
    "request": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
                "description": "7자리 TR코드를 세팅합니다. 이 TR의 경우 'ka10001'을 입력합니다."
            },
            {
                "element": "authorization",
                "name_ko": "접근토큰",
                "type": "String",
                "required": true,
                "length": "1000",
                "description": "발급받은 접근토큰 뒤에 토큰타입(\"Bearer \")을 결합하여 호출합니다."
            },
            {
                "element": "cont-yn",
                "name_ko": "연속조회여부",
                "type": "String",
                "required": false,
                "length": "1",
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음 데이터 요청 시 응답 Header의 cont-yn값을 그대로 세팅합니다."
            },
            {
                "element": "next-key",
                "name_ko": "연속조회키",
                "type": "String",
                "required": false,
                "length": "50",
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음 데이터 요청 시 응답 Header의 next-key값을 세팅합니다."
            }
        ],
        "body": [
            {
                "element": "stk_cd",
                "name_ko": "종목코드",
                "type": "String",
                "required": true,
                "length": "20",
                "description": "거래소별 종목코드를 입력합니다. (예: KRX 정규주식은 '039490', 대체거래소 NXT는 '039490_NX', SOR은 '039490_AL')"
            }
        ]
    },
    "response": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
