{
    "tr_id": "ka10007",
    "tr_name": "시세표성정보요청",
    "category": {
        "main": "국내주식",
        "sub": "시세"
    },
    "usage": {
        "description": "지정한 주식 종목의 현재가, 대비기호, 등락률, 전일비, 시가, 고가, 저가 뿐만 아니라 질문하신 '당일 거래량(trde_qty)' 및 전일 거래량, 10단계 매도/매수 호가와 호가별 잔량까지 종목의 핵심 시세판 정보를 단건으로 전량 조회합니다.",
        "method": "POST",
        "environment_domains": {
            "production": "https://api.kiwoom.com",
            "mock_investment": "https://mockapi.kiwoom.com(KRX만 지원가능)"
        },
        "url_path": "/api/dostk/mrkcond",
        "format": "JSON",
        "content_type": "application/json;charset=UTF-8"
    },
    "request": {
        "headers": [
            {
                "element": "api-id",
                "name_ko": "TR명",
                "type": "String",
                "required": true,
                "length": "10",
                "description": "7자리 TR코드를 세팅합니다. 이 TR의 경우 'ka1007'을 입력합니다."
            },
            {
                "element": "authorization",
                "name_ko": "접근토큰",
                "type": "String",
                "required": true,
                "length": "1000",
                "description": "발급받은 접근토큰 뒤에 토큰타입(\"Bearer \")을 결합하여 호출합니다."
            },
            {
                "element": "cont-yn",
                "name_ko": "연속조회여부",
                "type": "String",
                "required": false,
                "length": "1",
                "description": "응답 Header의 연속조회여부값이 Y일 경우 다음 데이터 요청 시 응답 Header의 cont-yn값을 그대로 세팅합니다. 단건 시세 조회이므로 보통 'N'입니다."
            },
            {
                "element": "next-key",
                "name_ko": "연속조회키",
                "type": "String",
                "required": false,
                "length": "50",
                "description": "연속조회 시 다음 데이터 호출을 위한 키값입니다."
            }
        ],
        "body": [
            {
                "element": "stk_cd",
                "name_ko": "종목코드",
                "type": "String",
                "required": true,
                "length": "20",
                "description": "거래소별 종목코드를 입력합니다. (KRX:005930, NXT:005930_NX, SOR:005930_AL)"
            }
        ]
    },
